# Environment variables required to run the trader
# Copy this file to .env and fill in your values, then source it:
#   source .env
#
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# REQUIRED API KEYS
#   Create these in Coinbase Advanced Trade -> Settings -> API.
#   - PAPER mode: read access is enough (used for market data).
#   - LIVE mode:  the key MUST have the 'Trade' permission.
# ---------------------------------------------------------------------------
export CB_API_KEY="your_coinbase_api_key_here"
export CB_API_SECRET="your_coinbase_api_secret_here"
export DISCORD_WEBHOOK_URL="your_new_discord_webhook_url_here"

# ---------------------------------------------------------------------------
# PAPER vs LIVE  (the flag that switches simulation to real money)
#   TRADING_MODE          = "paper" (default, simulated) or "live" (real orders)
#   LIVE_TRADING_ENABLED  = safety confirmation. Real orders are placed ONLY when
#                           TRADING_MODE=live AND LIVE_TRADING_ENABLED=true.
# To go live you must set BOTH:
#   export TRADING_MODE="live"
#   export LIVE_TRADING_ENABLED="true"
# ---------------------------------------------------------------------------
export TRADING_MODE="paper"
export LIVE_TRADING_ENABLED="false"

# ---------------------------------------------------------------------------
# STRATEGY / RISK SETTINGS (defaults shown)
# ---------------------------------------------------------------------------
export MIN_PATTERN_SCORE_TO_BUY="80"     # only buy strong setups (0-100)
export RECENT_TRIGGER_CANDLES="3"        # keep a breakout valid for ~15 minutes on 5m candles
export MARKET_REGIME_FILTER="true"       # pause new alt buys when BTC is weak
export BTC_15M_MAX_DROP_PCT="-0.35"      # pause if BTC drops more than this over 15m
export BTC_1H_MAX_DROP_PCT="-0.80"       # pause if BTC drops more than this over 1h
export MIN_REL_STRENGTH_VS_BTC="0.50"    # alt must beat BTC by this much over 1h
export MIN_24H_DOLLAR_VOLUME="5000000"   # liquidity proxy / market activity floor
export MIN_BREAKOUT_DOLLAR_VOLUME="25000" # breakout candle must have real traded value
export OBV_CONFIRMATION="true"           # require OBV accumulation before buying
export OBV_LOOKBACK_CANDLES="12"         # 12 x 5m = 1 hour OBV window
export MIN_OBV_PRESSURE_PCT="8.0"        # normalized OBV accumulation threshold
export MIN_OBV_UP_VOLUME_RATIO="0.52"    # at least 52% of recent volume on up closes
export CAPITAL_PER_TRADE_USD="1000"      # $ per coin
export MAX_OPEN_POSITIONS="10"           # max simultaneous coins
export MAX_DAILY_LOSS_PER_COIN="100"     # per-coin daily loss cap; pauses coin for the day
export TAKE_PROFIT_PERCENT="15.0"        # first take-profit target
export TRAILING_PERCENT="5.0"            # base trailing stop distance
export BREAKEVEN_STOP_ENABLED="true"     # protect capital after a trade starts working
export BREAKEVEN_TRIGGER_PCT="1.2"       # raise stop once unrealized gain reaches this %
export BREAKEVEN_BUFFER_PCT="0.15"       # breakeven stop sits entry + this %
export BEARISH_EXIT_MIN_PROFIT_PCT="3.0" # bearish early exit must lock at least this gain
export BEARISH_EXIT_MAX_LOSS_PCT="-1.0"  # bearish early exit may cut a real drawdown here
export BEARISH_EXIT_MIN_HOLD_MINUTES="90" # allow stalled tiny winners to exit after this
export BEARISH_EXIT_STALL_PROFIT_PCT="0.75" # max profit considered stalled after min hold
